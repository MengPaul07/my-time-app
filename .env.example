# Expo public envs (safe to commit as template)
EXPO_PUBLIC_SUPABASE_URL=https://your-project-id.supabase.co
EXPO_PUBLIC_SUPABASE_ANON_KEY=your-supabase-anon-key

# Optional frontend fallback keys (prefer storing real keys in Supabase app_secrets)
EXPO_PUBLIC_DEEPSEEK_API_KEY=
EXPO_PUBLIC_BAIDU_API_KEY=
EXPO_PUBLIC_BAIDU_SECRET_KEY=

# Optional local backend URL for development
EXPO_PUBLIC_BACKEND_URL=http://localhost:3000
