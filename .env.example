# ============================================================
# MyTime App - Frontend Environment Variables
# ============================================================
# Copy this file to .env and fill in your own values.
# All EXPO_PUBLIC_ variables are bundled into the client app.
# ============================================================

# --- Supabase (Required) ---
# Get these from your Supabase project: Dashboard → Project Settings → API
EXPO_PUBLIC_SUPABASE_URL=https://your-project-id.supabase.co
EXPO_PUBLIC_SUPABASE_ANON_KEY=your-supabase-anon-key

# --- AI / LLM (Optional - needed for AI assistant features) ---
# DeepSeek API key: https://platform.deepseek.com/
EXPO_PUBLIC_DEEPSEEK_API_KEY=your-deepseek-api-key

# --- Baidu OCR (Optional - needed for schedule image import) ---
# Baidu AI Console: https://console.bce.baidu.com/ai/
EXPO_PUBLIC_BAIDU_API_KEY=your-baidu-api-key
EXPO_PUBLIC_BAIDU_SECRET_KEY=your-baidu-secret-key

# --- Backend URL (Optional - only if running the local backend) ---
# Point this to your running backend server (see /backend)
EXPO_PUBLIC_BACKEND_URL=http://localhost:3001
