{
  "cli": {
    "version": ">= 16.28.0",
    "appVersionSource": "local"
  },
  "build": {
    "development": {
      "developmentClient": true,
      "distribution": "internal"
    },
    "preview": {
      "channel": "preview",
      "android": {
        "buildType": "apk",
        "env": {
          "APP_ABI_FILTERS": "arm64-v8a"
        }
      },
      "ios": {
        "simulator": true
      }
    },
    "production": {
      "channel": "production",
      "autoIncrement": true,
      "android": {
        "buildType": "apk",
        "env": {
          "APP_ABI_FILTERS": "arm64-v8a"
        }
      }
    }
  },
  "submit": {
    "production": {}
  }
}