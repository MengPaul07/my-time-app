# ============================================================
# MyTime App - Backend Environment Variables
# ============================================================
# Copy this file to .env and fill in your own values.
# ============================================================

# --- Server ---
PORT=3001

# --- DeepSeek AI (Required for AI assistant endpoint) ---
# Get your key at: https://platform.deepseek.com/
DEEPSEEK_API_KEY=your-deepseek-api-key

# --- Baidu OCR (Required for schedule image import endpoint) ---
# Get your keys at: https://console.bce.baidu.com/ai/
BAIDU_API_KEY=your-baidu-api-key
BAIDU_SECRET_KEY=your-baidu-secret-key
